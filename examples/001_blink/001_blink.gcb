''' ================================================================
''' 001_blink.gcb
''' Smallest REDBOARD behavior: make RC0 blink.
''' ================================================================

#chip 16F18424
#option Explicit
#config LVP = ON
#config MCLRE = ON

#include "../../nugget_fwlib_all.inc"

RB_Board_Init
RB_LED_Status_Init
Do
    RB_LED_Status_On
    Wait 500 ms
    RB_LED_Status_Off
    Wait 500 ms
Loop
